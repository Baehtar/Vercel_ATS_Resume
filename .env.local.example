# Supabase (client-side — must be prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key (server-side ONLY — never expose to the browser).
# Used for trusted admin writes (e.g. editing keyword_options) that bypass RLS.
# Find it in Supabase dashboard → Settings → API → service_role secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Where Supabase auth emails (verification / password recovery) redirect back to.
# In production set this to your Vercel URL, e.g. https://your-app.vercel.app
NEXT_PUBLIC_AUTH_REDIRECT_URL=http://localhost:3000

# OpenAI (server-side only — never exposed to the browser)
OPENAI_API_KEY=your-openai-key
# Optional: custom OpenAI-compatible endpoint (e.g. Azure OpenAI proxy)
OPENAI_API_BASE=
OPENAI_MODEL=gpt-3.5-turbo


RAPIDAPI_KEY=
CRON_SECRET=